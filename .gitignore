# State files (created at runtime in user's spec directory)
.ralph-state.json
**/.progress.md
specs/.current-spec

# Lock files (parallel execution)
**/.tasks.lock
**/.git-commit.lock

# Active spec pointer (user-specific)
specs/.current-spec

# Speckit state files
.specify/.current-feature
**/.speckit-state.json
**/.progress-task-*.md

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
.playwright-mcp

# Test fixtures
test-ac-*/

# Claude
.claude/worktrees/**

# E2E UI map (project-specific selector map, generated per installation)
# Never commit — regenerate with skills/e2e/ui-map-init.skill.md
**/ui-map.local.md

# E2E local environment config (contains auth mode, URLs, env var references)
# Never commit — copy from playwright-env.local.md.example and fill in locally
playwright-env.local.md
**/playwright-env.local.md

# E2E pre-authenticated browser state (contains session cookies/tokens)
# Never commit — generate with: npx playwright codegen --save-storage=.ralph-auth-state.json
.ralph-auth-state.json
**/.ralph-auth-state.json
node_modules
.claude/settings.json
